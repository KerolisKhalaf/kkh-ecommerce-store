# 🚀 PRODUCTION ENVIRONMENT CONFIGURATION (EXAMPLE)
# استخدم هذا الملف كقالب للإنتاج
# نسخ هذا الملف إلى .env.production وحدّث المفاتيح بالقيم الفعلية

# ============= DATABASE =============
# استخدم MongoDB Atlas للبروداكشن
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# ============= SERVER CONFIGURATION =============
PORT=5000
NODE_ENV=production

# ============= JWT =============
# استخدم مفتاح عشوائي قوي - توليد باستخدام:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-a-strong-random-secret-key>
JWT_EXPIRE=7d

# ============= STRIPE PAYMENT GATEWAY =============
# استخدم LIVE Keys من Stripe Dashboard
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ============= CORS CONFIGURATION =============
# حدد النطاقات الفعلية فقط
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ============= EMAIL CONFIGURATION =============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your-email@example.com>
EMAIL_PASSWORD=<your-app-password>
